{
  "name": "Flutter",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/jarrodcolburn/features/flutter-sdk:0": {}
  },
  "containerEnv": {
    "PUB_CACHE": "/workspaces/.pub-cache"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter"
      ]
    }
  },
  "postCreateCommand": "flutter pub get"
}